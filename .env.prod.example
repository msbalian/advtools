# Arquivo de exemplo para deploy em PRODUÇÃO (VPS)
# Copie este arquivo para .env na raiz do servidor em produção e preencha com senhas fortes.

# ── Configuração do Banco de Dados (PostgreSQL Docker) ───────────────────────
# O POSTGRES_HOST aqui deve apontar para o nome do serviço no docker-compose.prod.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=insira_uma_senha_forte_aqui
POSTGRES_DB=advtools-db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Chaves de API ────────────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_do_gemini_aqui
DATAJUD_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==

# ── Configurações de Segurança e JWT ─────────────────────────────────────────
SECRET_KEY=gere_uma_chave_secreta_longa_e_aleatoria_aqui_exemplo_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Usuário Administrador e Escritório Raiz (Padrão) ─────────────────────
# Estes dados serão usados no primeiro start para criar o admin master (se o banco estiver vazio)
FIRST_ADMIN_NAME=Seu Nome
FIRST_ADMIN_EMAIL=contato@seudominio.com.br
FIRST_ADMIN_PASSWORD=uma_senha_forte

FIRST_OFFICE_NAME="Nome do Seu Escritório"
FIRST_OFFICE_DOC="00.000.000/0001-00"

# ── Configurações do Frontend (Vite) / Retorno da API ─────────────────────────
# Quais origens podem acessar sua API (CORS) - inclua o domínio do seu frontend
CORS_ORIGINS=https://app.advtools.com.br
