# ── CONFIGURAÇÕES GERAIS DO ADVTOOLS ──────────────────────────────────────────
# Copie este arquivo para .env na RAIZ do projeto e preencha os valores.

# ── Configuração do Banco de Dados (PostgreSQL Docker) ───────────────────────
# Local: POSTGRES_HOST=localhost
# Docker/Produção: POSTGRES_HOST=postgres (ou o nome do serviço no docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=insira_uma_senha_forte_aqui
POSTGRES_DB=advtools-db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Sistema e Localização ───────────────────────────────────────────────────
# O sistema autodetecta TZ ou APP_TIMEZONE
TZ=America/Sao_Paulo
APP_TIMEZONE=America/Sao_Paulo

# ── Chaves de API ────────────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_do_gemini_aqui
DATAJUD_KEY=sua_chave_do_datajud_aqui

# ── Integrações Judiciais (MNI/Projudi) ──────────────────────────────────────
PROJUDI_USER=seu_usuario_projudi_aqui
PROJUDI_PASSWORD=sua_senha_projudi_aqui

# ── Configurações de Segurança e JWT ─────────────────────────────────────────
# Gere uma chave forte (ex: openssl rand -hex 32)
SECRET_KEY=uma_chave_secreta_longa_e_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Usuário Administrador e Escritório Raiz (Padrão) ────────────────────────
# Estes dados serão usados no primeiro start para criar o admin master (se o banco estiver vazio)
FIRST_ADMIN_NAME=Super Admin
FIRST_ADMIN_EMAIL=admin@advtools.com.br
FIRST_ADMIN_PASSWORD=senha_inicial_aqui

FIRST_OFFICE_NAME="ADVtools Advocacia"
FIRST_OFFICE_DOC="00.000.000/0001-00"

# ── URLs e Acesso (Frontend & API) ──────────────────────────────────────────
# VITE_API_URL: Usada pelo Frontend (Vite) para saber onde está a API
# FRONTEND_URL: Usada pelo Backend para gerar links de retorno (ex: recuperação de senha)
# CORS_ORIGINS: Domínios permitidos para acessar a API (pode ser lista separada por vírgula)

VITE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Mailing (SMTP) ──────────────────────────────────────────────────────────
MAIL_USERNAME=contato@seudominio.com.br
MAIL_PASSWORD=coloque_sua_senha_aqui
MAIL_FROM=contato@seudominio.com.br
MAIL_FROM_NAME=ADVtools
MAIL_SERVER=mail.seudominio.com.br
MAIL_PORT=465
MAIL_STARTTLS=False
MAIL_SSL_TLS=True
