# ── Configuração do Banco de Dados (PostgreSQL Docker) ───────────────────────
# Estas variáveis são usadas tanto pelo docker-compose quanto pela aplicação.
# Copie este arquivo para .env na RAIZ do projeto e preencha os valores.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_aqui
POSTGRES_DB=advtools-db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Chaves de API ────────────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_do_gemini_aqui
DATAJUD_KEY=sua_chave_do_datajud_aqui

# ── Configurações de Segurança e JWT ─────────────────────────────────────────
SECRET_KEY=uma_chave_secreta_longa_e_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Usuário Administrador e Escritório Raiz (Padrão) ─────────────────────
FIRST_ADMIN_NAME=Admin
FIRST_ADMIN_EMAIL=admin@exemplo.com
FIRST_ADMIN_PASSWORD=senha_inicial_aqui

FIRST_OFFICE_NAME="Seu Escritório"
FIRST_OFFICE_DOC="00.000.000/0000-00"

# ── Configurações do Frontend (Vite) ──────────────────────────────────────────
VITE_API_URL=http://localhost:8000
